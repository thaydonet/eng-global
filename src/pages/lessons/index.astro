---
import Layout from '@/layouts/Layout.astro';
import { getSubjectGradeCombinations } from '@/lib/lessons';

const combinations = getSubjectGradeCombinations();

// Map icons/colors for each subject
const subjectConfig: Record<string, { icon: string; gradient: string }> = {
  'toan': {
    icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
    gradient: 'from-blue-500 to-indigo-600'
  },
  'ly': {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    gradient: 'from-yellow-400 to-orange-500'
  },
  'hoa': {
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
    gradient: 'from-green-500 to-emerald-600'
  },
  'van': {
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
    gradient: 'from-rose-400 to-pink-500'
  },
  'anh': {
     icon: 'M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129',
     gradient: 'from-purple-500 to-violet-600'
  },
  'sinh': {
    icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
    gradient: 'from-green-400 to-teal-500'
  },
  'su': {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    gradient: 'from-orange-400 to-red-500'
  },
  'dia': {
    icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    gradient: 'from-blue-400 to-cyan-500'
  },
  'tin': {
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    gradient: 'from-indigo-400 to-blue-500'
  },
  'gdpl': {
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
    gradient: 'from-red-400 to-pink-500'
  }
};
---

<Layout title="Danh mục các môn học">
  <!-- Hero Section -->
  <div class="relative bg-gradient-to-br from-primary-600 via-secondary-600 to-accent-500 text-white py-20 overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 right-0 w-1/3 h-full opacity-10">
      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
         <path fill="currentColor" d="M44.7,-76.4C58.8,-69.2,71.8,-59.1,79.6,-45.8C87.4,-32.6,90,-16.3,88.5,-0.9C87,14.6,81.4,29.2,73.1,42.8C64.8,56.4,53.8,69,40.4,76.8C27,84.6,11.2,87.6,-4.8,85.9C-20.8,84.2,-37,77.8,-50.6,68.2C-64.2,58.6,-75.2,45.8,-81.4,30.8C-87.6,15.8,-89,-1.4,-85.2,-17.4C-81.4,-33.4,-72.4,-48.2,-60.2,-56.4C-48,-64.6,-32.6,-66.2,-18.2,-71C-3.8,-75.8,9.6,-83.8,24.7,-86.4C39.8,-89,56.6,-86.2,44.7,-76.4Z" transform="translate(100 100)" />
      </svg>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-display font-bold mb-6">Khám phá tri thức</h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto">Chọn môn học bạn muốn chinh phục hôm nay</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {combinations.map((combo) => {
        const config = subjectConfig[combo.subject.id] || { 
            icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', 
            gradient: 'from-gray-500 to-gray-600'
        };

        return (
          <a href={`/lessons/${combo.slug}`} class="block group h-full">
            <div class="bg-white rounded-2xl shadow-soft hover:shadow-soft-lg transform hover:-translate-y-1 transition-all duration-300 h-full overflow-hidden border border-gray-100 flex flex-col">
              <div class={`h-32 bg-gradient-to-br ${config.gradient} relative overflow-hidden flex items-center justify-center`}>
                <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                 <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center shadow-lg transform group-hover:scale-110 transition-transform duration-300">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={config.icon} />
                    </svg>
                 </div>
              </div>
              <div class="p-8 flex-1 flex flex-col items-center text-center">
                <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-primary-600 transition-colors">{combo.subject.name} {combo.grade.name}</h3>
                <p class="text-gray-600 mb-6 leading-relaxed flex-1">
                  {combo.lessonCount} bài học chất lượng cao dành cho học sinh {combo.grade.name}.
                </p>
                <div class="w-full">
                    <span class="inline-flex items-center justify-center w-full px-4 py-2 bg-gray-50 text-gray-700 font-medium rounded-lg group-hover:bg-primary-50 group-hover:text-primary-700 transition-colors">
                        Bắt đầu học
                        <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </span>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
