---
import Layout from '@/layouts/Layout.astro';
import ProgressTracker from '@/components/ProgressTracker.astro';
import { getAllLessons, getLessonById, getAdjacentLessons, getLessonsByChapter, getLessonsBySubjectAndGrade, parseSubjectGrade, getSubjectGradeCombinations } from '@/lib/lessons';

export async function getStaticPaths() {
  const lessons = getAllLessons();
  const combinations = getSubjectGradeCombinations();
  
  const paths = [];
  combinations.forEach(combo => {
    const prefix = combo.subject.id + combo.grade.id;
    const comboLessons = lessons.filter(l => l.id.startsWith(prefix));
    
    comboLessons.forEach(lesson => {
      paths.push({
        params: { 
          subjectGrade: combo.slug,
          id: lesson.id 
        },
        props: { lesson },
      });
    });
  });
  
  return paths;
}

const { lesson } = Astro.props;
const adjacentLessons = getAdjacentLessons(lesson.id);

// Get all lessons for progress calculation
const allLessons = getAllLessons();

// Get all lessons in the same chapter
const chapterLessons = getLessonsByChapter(lesson.chapter_id);

// Parse subject-grade from URL
const subjectGradeSlug = Astro.params.subjectGrade;
const parsed = parseSubjectGrade(subjectGradeSlug || '');

// Get all lessons for this subject-grade to show in sidebar
const subjectGradeLessons = parsed ? getLessonsBySubjectAndGrade(parsed.subjectId, parsed.gradeId) : [];

// Group lessons by chapter for sidebar
const lessonsByChapter = subjectGradeLessons.reduce((acc, currLesson) => {
  const chapterId = currLesson.chapter_id;
  if (!acc[chapterId]) {
    acc[chapterId] = {
      chapter: currLesson.chapter,
      lessons: []
    };
  }
  acc[chapterId].lessons.push(currLesson);
  return acc;
}, {} as Record<string, { chapter: string; lessons: typeof subjectGradeLessons }>);

const chapters = Object.values(lessonsByChapter);
---

<Layout title={lesson.name}>
  <div class="min-h-screen bg-gradient-to-br from-gray-50 via-blue-50/30 to-purple-50/20 dark:from-gray-900 dark:via-gray-900 dark:to-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center text-sm text-gray-600 dark:text-gray-400">
        <a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Trang chủ</a>
        <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="/lessons" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Bài học</a>
        <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <a href={`/lessons/${subjectGradeSlug}`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{lesson.conf_subject}</a>
        <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900 dark:text-gray-100 font-medium">{lesson.name}</span>
      </nav>

      <div class="flex flex-col lg:flex-row-reverse gap-8">
        <!-- Main Content -->
        <main class="flex-1 min-w-0">
          <!-- Lesson Header -->
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-soft p-8 mb-8">
            <div class="flex items-center gap-3 mb-4">
              <span class={`px-3 py-1 rounded-full text-sm font-semibold ${
                lesson.difficulty_level === 'easy' ? 'bg-success-100 dark:bg-success-900/30 text-success-700 dark:text-success-400' :
                lesson.difficulty_level === 'medium' ? 'bg-warning-100 dark:bg-warning-900/30 text-warning-700 dark:text-warning-400' :
                'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400'
              }`}>
                {lesson.difficulty_level === 'easy' ? '🟢 Dễ' : lesson.difficulty_level === 'medium' ? '🟡 Trung bình' : '🔴 Khó'}
              </span>
              <span class="text-sm text-gray-600 dark:text-gray-400 flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                {lesson.duration_minutes} phút
              </span>
            </div>

            <h1 class="text-3xl sm:text-4xl font-display font-bold text-gray-900 dark:text-gray-100 mb-4">
              {lesson.name}
            </h1>

            <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
              {lesson.description}
            </p>

            <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
              <span class="flex items-center">
                <svg class="w-5 h-5 mr-2 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
                Chương: {lesson.chapter}
              </span>
            </div>
          </div>

          <!-- Sub-lessons Grid (if lesson has sub-lessons) -->
          {lesson.has_sub_lessons && lesson.sub_lessons && (
            <section class="bg-white dark:bg-gray-800 rounded-2xl shadow-soft p-8 mb-8">
              <div class="mb-6">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">Các phần học</h2>
                <p class="text-gray-600 dark:text-gray-400">Bài học này được chia thành {lesson.sub_lessons.length} phần. Chọn một phần để bắt đầu học.</p>
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {lesson.sub_lessons.sort((a, b) => a.order - b.order).map((subLesson) => (
                  <a
                    href={`/lessons/${subjectGradeSlug}/${lesson.id}/${subLesson.slug}`}
                    class="group bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-6 border-2 border-blue-200 dark:border-blue-700 hover:border-blue-400 dark:hover:border-blue-500 hover:shadow-lg transition-all duration-300"
                  >
                    <div class="flex items-start gap-4">
                      <div class="flex-shrink-0">
                        <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-600 text-white flex items-center justify-center font-bold text-lg shadow-md">
                          {subLesson.order}
                        </div>
                      </div>
                      <div class="flex-1 min-w-0">
                        <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                          {subLesson.name}
                        </h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
                          {subLesson.description}
                        </p>
                        <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                          <span class={`px-2 py-1 rounded ${
                            subLesson.difficulty_level === 'easy' ? 'bg-success-100 dark:bg-success-900/30 text-success-700 dark:text-success-400' :
                            subLesson.difficulty_level === 'medium' ? 'bg-warning-100 dark:bg-warning-900/30 text-warning-700 dark:text-warning-400' :
                            'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400'
                          }`}>
                            {subLesson.difficulty_level === 'easy' ? '🟢 Dễ' : subLesson.difficulty_level === 'medium' ? '🟡 TB' : '🔴 Khó'}
                          </span>
                          <span class="flex items-center">
                            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            {subLesson.duration_minutes} phút
                          </span>
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}

          <!-- Theory Section (only if lesson doesn't have sub-lessons) -->
          {!lesson.has_sub_lessons && lesson.content?.theory && (
            <section class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl shadow-soft border-2 border-blue-200 dark:border-blue-700 p-8 mb-8">
              <div class="bg-gradient-to-r from-primary-600 to-indigo-600 text-white rounded-xl p-4 mb-6 shadow-md">
                <h2 class="text-2xl font-bold flex items-center">
                  <svg class="w-7 h-7 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                  </svg>
                  {lesson.content.theory.title}
                </h2>
              </div>

              <div class="space-y-6">
                {lesson.content.theory.sections.map((section) => (
                  <div class="prose prose-lg dark:prose-invert max-w-none bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm">
                    <h3 class="text-xl font-semibold text-blue-900 dark:text-blue-300 mb-3">{section.heading}</h3>
                    <div class="text-gray-700 dark:text-gray-300 latex-content" set:html={section.content} />
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Problem Types Section -->
          {!lesson.has_sub_lessons && lesson.content?.problemTypes && lesson.content.problemTypes.length > 0 && (
            <section class="bg-gradient-to-br from-orange-50 to-amber-50 dark:from-orange-900/20 dark:to-amber-900/20 rounded-2xl shadow-soft border-2 border-orange-200 dark:border-orange-700 p-8 mb-8">
              <div class="bg-gradient-to-r from-secondary-600 to-orange-600 text-white rounded-xl p-4 mb-6 shadow-md">
                <h2 class="text-2xl font-bold flex items-center">
                  <svg class="w-7 h-7 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                  </svg>
                  Các dạng bài tập
                </h2>
              </div>

              <div class="space-y-8">
                {lesson.content.problemTypes.map((problemType, index) => (
                  <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border-l-4 border-secondary-500 dark:border-secondary-400">
                    <h3 class="text-xl font-bold text-secondary-700 dark:text-secondary-300 mb-4">
                      Dạng {index + 1}: {problemType.name}
                    </h3>

                    {problemType.method && (
                      <div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl p-4 mb-4 border border-blue-200 dark:border-blue-700">
                        <h4 class="font-semibold text-blue-900 dark:text-blue-300 mb-2 flex items-center">
                          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                          </svg>
                          Phương pháp giải:
                        </h4>
                        <div class="text-blue-800 dark:text-blue-200 prose prose-sm dark:prose-invert latex-content" set:html={problemType.method} />
                      </div>
                    )}

                    {problemType.examples && problemType.examples.length > 0 && (
                      <div class="space-y-4">
                        <h4 class="font-semibold text-gray-900 dark:text-gray-100 flex items-center">
                          <svg class="w-5 h-5 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                          </svg>
                          Ví dụ:
                        </h4>
                        {problemType.examples.map((example, exIndex) => (
                          <div class="bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-700/50 dark:to-gray-600/50 rounded-xl p-4 border border-gray-200 dark:border-gray-600">
                            <div class="font-medium text-gray-900 dark:text-gray-100 mb-2 latex-content" set:html={example.question} />
                            <div class="text-gray-700 dark:text-gray-300 prose prose-sm dark:prose-invert latex-content" set:html={example.answer || example.solution} />
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Exercises Section -->
          {!lesson.has_sub_lessons && lesson.content?.exercises && lesson.content.exercises.length > 0 && (
            <section class="bg-white dark:bg-gray-800 rounded-2xl shadow-soft p-8 mb-8">
              <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 flex items-center">
                  <svg class="w-6 h-6 mr-3 text-accent-600 dark:text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  Bài tập ({lesson.content.exercises.length})
                </h2>
                <a 
                  href={`/quiz/${lesson.id}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-accent-600 to-accent-700 hover:from-accent-700 hover:to-accent-800 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-200"
                >
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                  </svg>
                  Làm bài tập ngay
                  <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              </div>
            </section>
          )}

          <!-- Lesson List in Chapter (only show if lesson doesn't have sub-lessons) -->
          {!lesson.has_sub_lessons && (
            <section class="mt-16 pt-8 border-t-2 border-gray-200 dark:border-gray-700">
              <div class="mb-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                  </svg>
                  Các bài học trong chương: {lesson.chapter}
                </h3>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {chapterLessons.map((chapterLesson) => (
                  <a
                    href={`/lessons/${subjectGradeSlug}/${chapterLesson.id}`}
                    class={`group rounded-xl shadow-soft hover:shadow-soft-lg transition-all duration-300 p-5 border-2 ${
                      chapterLesson.id === lesson.id 
                        ? 'border-primary-500 bg-primary-50 dark:bg-primary-900/20' 
                        : 'bg-white dark:bg-gray-800 border-gray-100 dark:border-gray-700 hover:border-primary-400 dark:hover:border-primary-500'
                    }`}
                  >
                    <div class="flex items-start">
                      <div class="flex-shrink-0 mr-3">
                        <div class={`w-10 h-10 rounded-lg flex items-center justify-center shadow-md ${
                          chapterLesson.id === lesson.id
                            ? 'bg-primary-600 text-white'
                            : 'bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-700 dark:to-gray-600 text-gray-700 dark:text-gray-300 group-hover:from-primary-500 group-hover:to-primary-600 group-hover:text-white'
                        }`}>
                          <span class="font-bold text-sm">{chapterLesson.lesson_id}</span>
                        </div>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class={`text-sm font-bold leading-snug mb-2 ${
                          chapterLesson.id === lesson.id
                            ? 'text-primary-700 dark:text-primary-400'
                            : 'text-gray-900 dark:text-gray-100 group-hover:text-primary-600 dark:group-hover:text-primary-400'
                        }`}>
                          {chapterLesson.name}
                        </p>
                        <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                          <span class={`px-2 py-0.5 rounded ${
                            chapterLesson.difficulty_level === 'easy' ? 'bg-success-100 dark:bg-success-900/30 text-success-700 dark:text-success-400' :
                            chapterLesson.difficulty_level === 'medium' ? 'bg-warning-100 dark:bg-warning-900/30 text-warning-700 dark:text-warning-400' :
                            'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400'
                          }`}>
                            {chapterLesson.difficulty_level === 'easy' ? '🟢' : chapterLesson.difficulty_level === 'medium' ? '🟡' : '🔴'}
                          </span>
                          <span class="flex items-center">
                            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            {chapterLesson.duration_minutes}p
                          </span>
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}
        </main>

        <!-- Sidebar - Lesson List -->
        <aside class="lg:w-80 flex-shrink-0">
          <div class="sticky top-24 space-y-4">
            <!-- All Lessons List -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-soft border border-gray-100 dark:border-gray-700 overflow-hidden">
              <div class="p-4 bg-gradient-to-r from-primary-600 to-primary-700 text-white">
                <h3 class="text-lg font-bold flex items-center">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                  </svg>
                  Danh sách bài học
                </h3>
                <p class="text-sm text-white/80 mt-1">{subjectGradeLessons.length} bài học</p>
              </div>
              
              <div class="max-h-[calc(100vh-200px)] overflow-y-auto">
                {chapters.map((chapter) => (
                  <div class="border-b border-gray-200 dark:border-gray-700 last:border-0">
                    <div class="px-4 py-3 bg-gray-50 dark:bg-gray-700/50">
                      <h4 class="text-sm font-bold text-gray-900 dark:text-gray-100">{chapter.chapter}</h4>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                      {chapter.lessons.map((sidebarLesson) => (
                        <a
                          href={`/lessons/${subjectGradeSlug}/${sidebarLesson.id}`}
                          class={`block px-4 py-3 transition-colors ${
                            sidebarLesson.id === lesson.id
                              ? 'bg-primary-50 dark:bg-primary-900/20 border-l-4 border-primary-600'
                              : 'hover:bg-gray-50 dark:hover:bg-gray-700/50 border-l-4 border-transparent'
                          }`}
                        >
                          <div class="flex items-start gap-3">
                            <div class={`flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold ${
                              sidebarLesson.id === lesson.id
                                ? 'bg-primary-600 text-white'
                                : 'bg-gray-200 dark:bg-gray-600 text-gray-700 dark:text-gray-300'
                            }`}>
                              {sidebarLesson.lesson_id}
                            </div>
                            <div class="flex-1 min-w-0">
                              <p class={`text-sm font-medium leading-tight line-clamp-2 ${
                                sidebarLesson.id === lesson.id
                                  ? 'text-primary-700 dark:text-primary-400'
                                  : 'text-gray-900 dark:text-gray-100'
                              }`}>
                                {sidebarLesson.name}
                              </p>
                              <div class="flex items-center gap-2 mt-1">
                                <span class={`text-xs px-1.5 py-0.5 rounded ${
                                  sidebarLesson.difficulty_level === 'easy' ? 'bg-success-100 dark:bg-success-900/30 text-success-700 dark:text-success-400' :
                                  sidebarLesson.difficulty_level === 'medium' ? 'bg-warning-100 dark:bg-warning-900/30 text-warning-700 dark:text-warning-400' :
                                  'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400'
                                }`}>
                                  {sidebarLesson.difficulty_level === 'easy' ? '🟢' : sidebarLesson.difficulty_level === 'medium' ? '🟡' : '🔴'}
                                </span>
                                <span class="text-xs text-gray-500 dark:text-gray-400 flex items-center">
                                  <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                  </svg>
                                  {sidebarLesson.duration_minutes}p
                                </span>
                              </div>
                            </div>
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</Layout>

<!-- KaTeX Auto-render Script -->
<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" integrity="sha384-XjKyOOlGwcjNTAIQHIpgOno0Hl1YQqzUOEleOLALmuqehneUG+vnGctmUb0ZY0l8" crossorigin="anonymous"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" integrity="sha384-+VBxd3r6XgURycqtZ117nYw44OOcIax56Z4dCRWbxyPt0Koah1uHoK0o4+/RRE05" crossorigin="anonymous"></script>
<script is:inline>
  // Auto-render LaTeX in all elements with class 'latex-content'
  document.addEventListener('DOMContentLoaded', function() {
    const latexElements = document.querySelectorAll('.latex-content');
    latexElements.forEach(element => {
      renderMathInElement(element, {
        delimiters: [
          {left: '$$', right: '$$', display: true},
          {left: '$', right: '$', display: false},
          {left: '\\[', right: '\\]', display: true},
          {left: '\\(', right: '\\)', display: false}
        ],
        throwOnError: false
      });
    });
  });
</script>

<style>
