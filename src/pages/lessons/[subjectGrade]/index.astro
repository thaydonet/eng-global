---
import Layout from '@/layouts/Layout.astro';
import LessonSearch from '@/components/LessonSearch.astro';
import { parseSubjectGrade, getLessonsBySubjectAndGrade, getSubjectGradeCombinations, getSubjects, getGrades } from '@/lib/lessons';

export async function getStaticPaths() {
  const combinations = getSubjectGradeCombinations();
  return combinations.map(combo => ({
    params: { subjectGrade: combo.slug },
    props: { 
      subjectGrade: combo,
      subjectId: combo.subject.id,
      gradeId: combo.grade.id
    }
  }));
}

const { subjectGrade, subjectId, gradeId } = Astro.props;
const lessons = getLessonsBySubjectAndGrade(subjectId, gradeId);
---

<Layout title={`${subjectGrade.subject.name} ${subjectGrade.grade.name}`}>
  <!-- Hero Section -->
  <div class="relative bg-gradient-to-br from-primary-600 via-secondary-600 to-accent-500 text-white py-16 overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 right-0 w-1/3 h-full opacity-10">
      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <path fill="currentColor" d="M44.7,-76.4C58.8,-69.2,71.8,-59.1,79.6,-45.8C87.4,-32.6,90,-16.3,88.5,-0.9C87,14.6,81.4,29.2,73.1,42.8C64.8,56.4,53.8,69,40.4,76.8C27,84.6,11.2,87.6,-4.8,85.9C-20.8,84.2,-37,77.8,-50.6,68.2C-64.2,58.6,-75.2,45.8,-81.4,30.8C-87.6,15.8,-89,-1.4,-85.2,-17.4C-81.4,-33.4,-72.4,-48.2,-60.2,-56.4C-48,-64.6,-32.6,-66.2,-18.2,-71C-3.8,-75.8,9.6,-83.8,24.7,-86.4C39.8,-89,56.6,-86.2,44.7,-76.4Z" transform="translate(100 100)" />
      </svg>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center mb-4">
        <a href="/lessons" class="text-white/80 hover:text-white transition-colors flex items-center text-sm font-medium">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Danh sách môn học
        </a>
      </div>
      <h1 class="text-4xl sm:text-5xl font-display font-bold mb-4">{subjectGrade.subject.name} {subjectGrade.grade.name}</h1>
      <p class="text-xl text-white/90 max-w-2xl">Danh sách các bài học chất lượng cao môn {subjectGrade.subject.name} {subjectGrade.grade.name}</p>

      <!-- Stats -->
      <div class="mt-8 grid grid-cols-2 gap-4 max-w-xl">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
          <div class="text-2xl font-bold mb-1">{lessons.length}</div>
          <div class="text-sm text-white/80">Bài học</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
          <div class="text-2xl font-bold mb-1">{subjectGrade.grade.name}</div>
          <div class="text-sm text-white/80">Khối lớp</div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <!-- Search and Filter -->
    <LessonSearch />

    {lessons.length > 0 ? (
      <>
        <!-- Lessons Grid -->
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {lessons.map((lesson, lessonIndex) => {
            const colors = [
              { gradient: 'from-primary-500 to-primary-600', border: 'border-primary-200', hover: 'hover:border-primary-400', text: 'text-primary-600' },
              { gradient: 'from-secondary-500 to-secondary-600', border: 'border-secondary-200', hover: 'hover:border-secondary-400', text: 'text-secondary-600' },
              { gradient: 'from-accent-500 to-accent-600', border: 'border-accent-200', hover: 'hover:border-accent-400', text: 'text-accent-600' },
            ];
            const colorScheme = colors[lessonIndex % 3];

            return (
              <a href={`/lessons/${subjectGrade.slug}/${lesson.id}`} class="block group">
                <div class={`bg-white rounded-2xl shadow-soft hover:shadow-soft-lg transition-all duration-300 overflow-hidden h-full border-2 ${colorScheme.border} ${colorScheme.hover}`}>
                  {/* Card Header */}
                  <div class={`h-32 bg-gradient-to-br ${colorScheme.gradient} relative overflow-hidden`}>
                    <div class="absolute inset-0 bg-black/5"></div>
                    <div class="absolute top-0 right-0 w-32 h-32 transform translate-x-8 -translate-y-8">
                      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-20">
                        <path fill="white" d="M44.7,-76.4C58.8,-69.2,71.8,-59.1,79.6,-45.8C87.4,-32.6,90,-16.3,88.5,-0.9C87,14.6,81.4,29.2,73.1,42.8C64.8,56.4,53.8,69,40.4,76.8C27,84.6,11.2,87.6,-4.8,85.9C-20.8,84.2,-37,77.8,-50.6,68.2C-64.2,58.6,-75.2,45.8,-81.4,30.8C-87.6,15.8,-89,-1.4,-85.2,-17.4C-81.4,-33.4,-72.4,-48.2,-60.2,-56.4C-48,-64.6,-32.6,-66.2,-18.2,-71C-3.8,-75.8,9.6,-83.8,24.7,-86.4C39.8,-89,56.6,-86.2,44.7,-76.4Z" transform="translate(100 100)" />
                      </svg>
                    </div>
                    <div class="relative z-10 p-6 flex items-center justify-between h-full">
                      <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center shadow-lg">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                      </div>
                    </div>
                  </div>

                  {/* Card Body */}
                  <div class="p-6">
                    {/* Meta Info */}
                    <div class="flex items-center gap-2 mb-3">
                      <span class={`px-3 py-1 rounded-full text-xs font-semibold ${
                        lesson.difficulty_level === 'easy' ? 'bg-success-100 text-success-700' :
                        lesson.difficulty_level === 'medium' ? 'bg-warning-100 text-warning-700' :
                        'bg-red-100 text-red-700'
                      }`}>
                        {lesson.difficulty_level === 'easy' ? '🟢 Dễ' : lesson.difficulty_level === 'medium' ? '🟡 Trung bình' : '🔴 Khó'}
                      </span>
                      <span class="text-sm text-gray-500 flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        {lesson.duration_minutes} phút
                      </span>
                    </div>

                    {/* Chapter Badge */}
                    <div class="mb-3">
                      <span class={`inline-block px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wide bg-gradient-to-r ${colorScheme.gradient} text-white`}>
                        {lesson.chapter}
                      </span>
                    </div>

                    {/* Title */}
                    <h3 class={`text-lg font-bold mb-2 text-gray-900 group-hover:${colorScheme.text} transition-colors line-clamp-2 min-h-[3.5rem]`}>
                      {lesson.name}
                    </h3>

                    {/* Description */}
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2 leading-relaxed">
                      {lesson.description}
                    </p>

                    {/* CTA */}
                    <div class="flex items-center justify-between">
                      <div class={`flex items-center ${colorScheme.text} font-semibold text-sm group-hover:translate-x-1 transition-transform`}>
                        <span>Xem bài học</span>
                        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                        </svg>
                      </div>
                      <div class="lesson-progress-indicator" data-lesson-id={lesson.id}>
                        {/* Progress icon will be inserted by JS */}
                      </div>
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </>
    ) : (
      <div class="text-center py-16">
        <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Không tìm thấy bài học</h3>
        <p class="text-gray-600">Hiện tại chưa có bài học nào cho {subjectGrade.subject.name} {subjectGrade.grade.name}.</p>
      </div>
    )}
  </div>
</Layout>

<script>
  // Show progress indicators on lesson cards
  const STORAGE_KEY = 'lms_lesson_progress';
  const progressData = localStorage.getItem(STORAGE_KEY);

  if (progressData) {
    const progress = JSON.parse(progressData);
    const indicators = document.querySelectorAll('.lesson-progress-indicator');

    indicators.forEach((indicator) => {
      const lessonId = indicator.getAttribute('data-lesson-id');
      if (lessonId && progress[lessonId]?.completed) {
        indicator.innerHTML = `
          <svg class="w-6 h-6 text-success-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
          </svg>
        `;
      }
    });
  }
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
