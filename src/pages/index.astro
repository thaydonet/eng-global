---
import Layout from '@/layouts/Layout.astro';
import NewInfoSection from '@/components/NewInfoSection.tsx';
import { getLatestLessons } from '@/lib/lessons';

const latestLessons = getLatestLessons(5);
---

<Layout title="Học Tiếng Anh - Global Success | Nền tảng học tập thông minh">
  <!-- ========== HERO SECTION ========== -->
  <section class="relative min-h-screen flex items-center overflow-hidden" id="hero">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 hero-bg"></div>
    <!-- Animated blobs -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <!-- Floating letters decoration -->
      <div class="floating-letter" style="top:15%;left:8%;animation-delay:0s">A</div>
      <div class="floating-letter" style="top:70%;left:5%;animation-delay:1.5s">英</div>
      <div class="floating-letter" style="top:25%;right:10%;animation-delay:0.8s">B</div>
      <div class="floating-letter" style="top:75%;right:8%;animation-delay:2.2s">C</div>
      <div class="floating-letter" style="top:50%;left:15%;animation-delay:3s;font-size:1.2rem">📚</div>
      <div class="floating-letter" style="top:20%;right:25%;animation-delay:1s;font-size:1.4rem">🎯</div>
    </div>
    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 50px 50px;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full text-white/90 text-sm font-medium mb-8 animate-fade-in-up">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Chương trình Global Success — Chuẩn Bộ GD&ĐT
      </div>

      <!-- Main title -->
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-black text-white leading-[1.05] mb-6 animate-fade-in-up" style="animation-delay:0.1s">
        Học Tiếng Anh
        <span class="block text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #fbbf24, #f472b6, #a78bfa);">
          Hiệu Quả
        </span>
        <span class="block text-4xl sm:text-5xl md:text-6xl font-bold mt-1 text-white/90">Cùng Global Success</span>
      </h1>

      <p class="text-xl md:text-2xl text-white/80 mb-12 max-w-3xl mx-auto leading-relaxed animate-fade-in-up" style="animation-delay:0.2s">
        Nền tảng học Tiếng Anh thông minh <strong class="text-white">lớp 6–12</strong> theo chương trình Global Success.
        Bài học chất lượng · Luyện tập đa dạng · Hoàn toàn miễn phí.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16 animate-fade-in-up" style="animation-delay:0.3s">
        <a href="/lessons/tieng-anh-12" class="cta-primary" id="hero-cta-main">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Bắt đầu học ngay
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="/huong-dan" class="cta-secondary" id="hero-cta-guide">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Xem hướng dẫn
        </a>
      </div>

      <!-- Stats bar -->
      <div class="inline-flex flex-wrap justify-center gap-8 sm:gap-12 px-8 py-5 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl text-white animate-fade-in-up" style="animation-delay:0.4s">
        <div class="text-center">
          <p class="text-3xl font-black text-white drop-shadow">7</p>
          <p class="text-xs text-white/70 font-medium mt-0.5">Khối lớp</p>
        </div>
        <div class="w-px bg-white/20 self-stretch"></div>
        <div class="text-center">
          <p class="text-3xl font-black text-white drop-shadow">100+</p>
          <p class="text-xs text-white/70 font-medium mt-0.5">Bài học</p>
        </div>
        <div class="w-px bg-white/20 self-stretch"></div>
        <div class="text-center">
          <p class="text-3xl font-black text-white drop-shadow">AI</p>
          <p class="text-xs text-white/70 font-medium mt-0.5">Hỗ trợ</p>
        </div>
        <div class="w-px bg-white/20 self-stretch"></div>
        <div class="text-center">
          <p class="text-3xl font-black text-emerald-300 drop-shadow">0đ</p>
          <p class="text-xs text-white/70 font-medium mt-0.5">Chi phí</p>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <a href="#grades" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/60 hover:text-white transition-colors animate-bounce">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </section>

  <!-- ========== GRADES SECTION ========== -->
  <section id="grades" class="py-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-50/50 to-transparent dark:via-blue-950/20"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 rounded-full text-sm font-semibold mb-4">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          Chọn khối lớp của bạn
        </div>
        <h2 class="text-4xl md:text-5xl font-display font-black text-gray-900 dark:text-white mb-4">
          Học <span class="gradient-text">Tiếng Anh</span> theo lớp
        </h2>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
          Chương trình Global Success chuẩn Bộ GD&ĐT — Nội dung đầy đủ, bài tập đa dạng cho từng khối lớp
        </p>
      </div>

      <!-- Grade cards grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-7 gap-4">
        {[
          { grade: 12, href: '/lessons/tieng-anh-12', color: 'from-violet-500 to-purple-600', glow: 'shadow-purple-200 dark:shadow-purple-900/50', icon: '🎓', label: 'THPT', border: 'hover:border-violet-300 dark:hover:border-violet-700' },
          { grade: 11, href: '/lessons/tieng-anh-11', color: 'from-blue-500 to-indigo-600', glow: 'shadow-blue-200 dark:shadow-blue-900/50', icon: '📖', label: 'THPT', border: 'hover:border-blue-300 dark:hover:border-blue-700' },
          { grade: 10, href: '/lessons/tieng-anh-10', color: 'from-cyan-500 to-blue-600', glow: 'shadow-cyan-200 dark:shadow-cyan-900/50', icon: '🚀', label: 'THPT', border: 'hover:border-cyan-300 dark:hover:border-cyan-700' },
          { grade: 9, href: '/lessons/tieng-anh-9', color: 'from-emerald-500 to-teal-600', glow: 'shadow-emerald-200 dark:shadow-emerald-900/50', icon: '🌟', label: 'THCS', border: 'hover:border-emerald-300 dark:hover:border-emerald-700' },
          { grade: 8, href: '/lessons/tieng-anh-8', color: 'from-amber-500 to-orange-600', glow: 'shadow-amber-200 dark:shadow-amber-900/50', icon: '💡', label: 'THCS', border: 'hover:border-amber-300 dark:hover:border-amber-700' },
          { grade: 7, href: '/lessons/tieng-anh-7', color: 'from-rose-500 to-pink-600', glow: 'shadow-rose-200 dark:shadow-rose-900/50', icon: '🎯', label: 'THCS', border: 'hover:border-rose-300 dark:hover:border-rose-700' },
          { grade: 6, href: '/lessons/tieng-anh-6', color: 'from-orange-400 to-red-500', glow: 'shadow-orange-200 dark:shadow-orange-900/50', icon: '🌱', label: 'THCS', border: 'hover:border-orange-300 dark:hover:border-orange-700' },
        ].map(({ grade, href, color, glow, icon, label, border }) => (
          <a href={href} class={`grade-card group ${border}`} id={`grade-card-${grade}`}>
            <div class={`grade-icon-wrap bg-gradient-to-br ${color} shadow-lg ${glow}`}>
              <span class="text-2xl font-black text-white leading-none">{grade}</span>
            </div>
            <span class="text-xl" aria-hidden="true">{icon}</span>
            <p class="font-bold text-gray-800 dark:text-white text-sm">Lớp {grade}</p>
            <span class="level-badge">{label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== FEATURES SECTION ========== -->
  <section class="py-20 bg-white dark:bg-gray-900" id="features">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 rounded-full text-sm font-semibold mb-4">
          ✨ Tính năng nổi bật
        </div>
        <h2 class="text-4xl md:text-5xl font-display font-black text-gray-900 dark:text-white mb-4">
          Tại sao chọn <span class="gradient-text">Global Success?</span>
        </h2>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
          Được thiết kế đặc biệt giúp học sinh Việt Nam học tiếng Anh hiệu quả và thú vị hơn
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="feature-card group">
          <div class="feature-icon-wrap bg-gradient-to-br from-blue-500 to-indigo-600">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Nội dung chuẩn SGK</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Bài giảng bám sát chương trình sách giáo khoa Global Success theo chuẩn Bộ GD&ĐT từ lớp 6 đến lớp 12.</p>
          <div class="feature-arrow">→</div>
        </div>

        <!-- Feature 2 -->
        <div class="feature-card group">
          <div class="feature-icon-wrap bg-gradient-to-br from-violet-500 to-purple-600">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Bài tập trắc nghiệm</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Hệ thống câu hỏi phong phú theo dạng thi thực tế, có giải thích chi tiết giúp các em tự kiểm tra và củng cố kiến thức.</p>
          <div class="feature-arrow">→</div>
        </div>

        <!-- Feature 3 -->
        <div class="feature-card group">
          <div class="feature-icon-wrap bg-gradient-to-br from-emerald-500 to-teal-600">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Trợ lý AI thông minh</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">AI hỗ trợ giải đáp thắc mắc 24/7. Từ ngữ pháp, từ vựng đến phát âm — mọi câu hỏi đều có lời giải thích tức thì.</p>
          <div class="feature-arrow">→</div>
        </div>

        <!-- Feature 4 -->
        <div class="feature-card group">
          <div class="feature-icon-wrap bg-gradient-to-br from-amber-500 to-orange-600">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Học mọi lúc, mọi nơi</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Tương thích hoàn hảo trên điện thoại, máy tính bảng và máy tính. Học offline khi cần thiết.</p>
          <div class="feature-arrow">→</div>
        </div>

        <!-- Feature 5 -->
        <div class="feature-card group">
          <div class="feature-icon-wrap bg-gradient-to-br from-rose-500 to-pink-600">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Thi đua & Bảng xếp hạng</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Hệ thống thi đua thú vị với bảng xếp hạng, giúp học sinh có động lực học tập mỗi ngày.</p>
          <div class="feature-arrow">→</div>
        </div>

        <!-- Feature 6 -->
        <div class="feature-card group">
          <div class="feature-icon-wrap bg-gradient-to-br from-cyan-500 to-blue-600">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Hoàn toàn miễn phí</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Tất cả nội dung, bài học và tính năng hoàn toàn <strong>miễn phí</strong>. Không cần đăng ký tài khoản trả phí.</p>
          <div class="feature-arrow">→</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRENDING SECTION ========== -->
  <section class="py-20 relative overflow-hidden" id="trending">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-950 via-blue-950 to-violet-950"></div>
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-500 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-violet-600 rounded-full blur-[100px]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 backdrop-blur-sm text-white/90 rounded-full text-sm font-semibold mb-4 border border-white/20">
          🔥 Đang thịnh hành
        </div>
        <h2 class="text-4xl md:text-5xl font-display font-black text-white mb-4">
          Xu hướng <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #60a5fa, #a78bfa, #f472b6)">học ngoại ngữ</span> 2025
        </h2>
        <p class="text-lg text-white/60 max-w-2xl mx-auto">
          Khám phá những phương pháp và xu hướng học tiếng Anh được yêu thích nhất hiện nay
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Trend 1: Grammar -->
        <div class="trend-card group" id="trend-grammar">
          <div class="trend-tag bg-blue-500/20 text-blue-300 border-blue-500/30">#1 Xu hướng</div>
          <div class="trend-icon">🧠</div>
          <h3 class="trend-title">Ngữ pháp thực chiến</h3>
          <p class="trend-desc">Học ngữ pháp qua tình huống giao tiếp thực tế thay vì học thuộc lòng công thức. Phương pháp được 95% giáo viên tiếng Anh khuyến khích.</p>
          <div class="trend-bar">
            <div class="trend-bar-fill" style="width:92%"></div>
          </div>
          <div class="flex justify-between text-xs text-white/50 mt-1 mb-4">
            <span>Mức độ phổ biến</span><span>92%</span>
          </div>
          <a href="/lessons/tieng-anh-12" class="trend-link">Khám phá bài học →</a>
        </div>

        <!-- Trend 2: Vocabulary -->
        <div class="trend-card group" id="trend-vocab">
          <div class="trend-tag bg-violet-500/20 text-violet-300 border-violet-500/30">#2 Hot nhất</div>
          <div class="trend-icon">📝</div>
          <h3 class="trend-title">Học từ vựng theo chủ đề</h3>
          <p class="trend-desc">Ghi nhớ từ vựng hiệu quả hơn thông qua các chủ đề quen thuộc trong sách giáo khoa. Kết hợp hình ảnh, âm thanh và ngữ cảnh sử dụng.</p>
          <div class="trend-bar">
            <div class="trend-bar-fill bg-gradient-to-r from-violet-500 to-purple-500" style="width:88%"></div>
          </div>
          <div class="flex justify-between text-xs text-white/50 mt-1 mb-4">
            <span>Mức độ phổ biến</span><span>88%</span>
          </div>
          <a href="/lessons/tieng-anh-11" class="trend-link">Khám phá bài học →</a>
        </div>

        <!-- Trend 3: Reading -->
        <div class="trend-card group" id="trend-reading">
          <div class="trend-tag bg-emerald-500/20 text-emerald-300 border-emerald-500/30">#3 Phổ biến</div>
          <div class="trend-icon">📖</div>
          <h3 class="trend-title">Kỹ năng đọc hiểu</h3>
          <p class="trend-desc">Luyện tập đọc hiểu với các dạng bài tập đa dạng: skimming, scanning, inference. Chuẩn bị cho thi tốt nghiệp và IELTS.</p>
          <div class="trend-bar">
            <div class="trend-bar-fill bg-gradient-to-r from-emerald-500 to-teal-500" style="width:85%"></div>
          </div>
          <div class="flex justify-between text-xs text-white/50 mt-1 mb-4">
            <span>Mức độ phổ biến</span><span>85%</span>
          </div>
          <a href="/lessons/tieng-anh-10" class="trend-link">Khám phá bài học →</a>
        </div>

        <!-- Trend 4: Speaking -->
        <div class="trend-card group" id="trend-speaking">
