---
import Layout from '@/layouts/Layout.astro';
import { getAllLessons } from '@/lib/lessons';

const lessons = getAllLessons();
const grades = ['6','7','8','9','10','11','12'];
const geminiKey = import.meta.env.PUBLIC_GEMINI_API_KEY || '';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

// Get URL param for pre-selected type
const preType = Astro.url.searchParams.get('type') || '';
---

<Layout title="Tạo đề thi AI | Global Success">
  <!-- Auth gate -->
  <div id="auth-gate" class="hidden min-h-screen flex items-center justify-center pt-20">
    <div class="text-center max-w-md mx-auto px-4">
      <div class="w-20 h-20 bg-purple-100 dark:bg-purple-900/30 rounded-2xl flex items-center justify-center mx-auto mb-5">
        <svg class="w-10 h-10 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <h2 class="text-2xl font-black text-gray-900 dark:text-gray-100 mb-3">Đăng nhập để tạo đề</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-6">Chỉ Admin và Giáo viên mới có thể tạo đề thi. Vui lòng đăng nhập.</p>
      <a href="/dang-nhap?redirect=/de-thi/tao-de" class="inline-flex items-center gap-2 px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-xl transition-all">
        Đăng nhập ngay
      </a>
    </div>
  </div>

  <!-- Creator UI (shown after auth check) -->
  <div id="creator-ui" class="hidden min-h-screen pt-20 pb-10">
    <!-- Header bar -->
    <div class="bg-gradient-to-r from-violet-700 to-purple-700 text-white py-10 px-4">
      <div class="max-w-5xl mx-auto">
        <a href="/de-thi" class="inline-flex items-center gap-1.5 text-white/70 hover:text-white text-sm mb-4 transition-colors">
          ← Kho đề thi
        </a>
        <h1 class="text-3xl font-black mb-2">✨ Tạo đề thi bằng AI</h1>
        <p class="text-white/80">Gemini AI sẽ tạo câu hỏi theo cấu hình của bạn trong vài giây</p>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
      <!-- Step indicator -->
      <div class="flex items-center justify-center mb-8">
        <div class="flex items-center gap-2" id="step-indicator">
          {[
            { n: 1, label: 'Cấu hình' },
            { n: 2, label: 'AI tạo câu' },
            { n: 3, label: 'Xem & Sửa' },
            { n: 4, label: 'Lưu & Xuất bản' },
          ].map((s, i) => (
            <>
              <div class={`step-item flex items-center gap-2 ${i === 0 ? 'active' : ''}`} data-step={s.n}>
                <span class={`step-dot w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold transition-all
                  ${i === 0 ? 'bg-purple-600 text-white' : 'bg-gray-200 dark:bg-gray-700 text-gray-500 dark:text-gray-400'}`}>
                  {s.n}
                </span>
                <span class={`hidden sm:block text-sm font-medium ${i === 0 ? 'text-purple-600 dark:text-purple-400' : 'text-gray-400'}`}>
                  {s.label}
                </span>
              </div>
              {i < 3 && <div class="step-line h-0.5 w-8 sm:w-16 bg-gray-200 dark:bg-gray-700"></div>}
            </>
          ))}
        </div>
      </div>

      <!-- STEP 1: Config -->
      <div id="step-1" class="step-panel">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Left: basic config -->
          <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm p-6 space-y-5">
            <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100">⚙️ Cấu hình đề thi</h2>

            <div>
              <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Tên đề thi *</label>
              <input id="cfg-title" type="text" placeholder="VD: Đề thi HK1 Tiếng Anh 12"
                class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-all text-sm"/>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Loại đề *</label>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2" id="type-selector">
                {[
                  { value: 'bai', emoji: '📖', label: 'Theo bài' },
                  { value: 'lop', emoji: '🏫', label: 'Theo lớp' },
                  { value: 'hoc-ky', emoji: '📅', label: 'Học kỳ' },
                  { value: 'thpt', emoji: '🎓', label: 'TN THPT 2026' },
                  { value: 'ma-tran', emoji: '📊', label: 'Ma trận' },
                ].map(t => (
                  <button data-type={t.value}
                    class={`type-btn flex flex-col items-center gap-1 p-3 rounded-xl border-2 transition-all text-center
                      ${preType === t.value
                        ? 'border-purple-500 bg-purple-50 dark:bg-purple-900/20'
                        : 'border-gray-200 dark:border-gray-600 hover:border-purple-400'}`}>
                    <span class="text-xl">{t.emoji}</span>
                    <span class="text-xs font-semibold text-gray-700 dark:text-gray-300">{t.label}</span>
                  </button>
                ))}
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Khối lớp</label>
                <select id="cfg-grade" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm focus:ring-2 focus:ring-purple-500 outline-none">
                  {grades.map(g => <option value={g}>Lớp {g}</option>)}
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Thời gian (phút)</label>
                <input id="cfg-duration" type="number" value="45" min="15" max="180"
                  class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm focus:ring-2 focus:ring-purple-500 outline-none"/>
              </div>
            </div>

            <!-- Semester (for hoc-ky) -->
            <div id="cfg-semester-group" class="hidden">
              <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Học kỳ</label>
              <div class="flex gap-3">
                <button class="semester-btn flex-1 py-2 rounded-xl border-2 border-gray-200 dark:border-gray-600 text-sm font-semibold hover:border-purple-400 transition-all" data-sem="1">Học kỳ 1</button>
                <button class="semester-btn flex-1 py-2 rounded-xl border-2 border-gray-200 dark:border-gray-600 text-sm font-semibold hover:border-purple-400 transition-all" data-sem="2">Học kỳ 2</button>
              </div>
            </div>

            <!-- Lesson picker (for bai) -->
            <div id="cfg-lesson-group" class="hidden">
              <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Chọn bài học</label>
              <select id="cfg-lesson" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm focus:ring-2 focus:ring-purple-500 outline-none">
                <option value="">-- Chọn bài --</option>
                {lessons.map(l => <option value={l.id}>{l.name}</option>)}
              </select>
            </div>
          </div>

          <!-- Right: AI config -->
          <div class="space-y-5">
            <!-- Questions config -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm p-6">
              <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-5">🤖 Cấu hình AI</h2>

              <div>
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
                  Số câu hỏi: <span id="num-q-display" class="text-purple-600 dark:text-purple-400">10</span>
                </label>
                <input id="cfg-num-questions" type="range" min="5" max="100" value="10" step="5"
                  class="w-full accent-purple-600"/>
                <div class="flex justify-between text-xs text-gray-400 mt-1">
                  <span>5</span><span>50</span><span>100</span>
                </div>
              </div>

              <div class="mt-5">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Phân phối mức độ</label>
                <div class="space-y-3" id="difficulty-mix">
                  {[
                    { key: 'nhan_biet', label: 'Nhận biết', color: 'green', default: 30 },
                    { key: 'thong_hieu', label: 'Thông hiểu', color: 'blue', default: 40 },
                    { key: 'van_dung', label: 'Vận dụng', color: 'orange', default: 20 },
                    { key: 'van_dung_cao', label: 'Vận dụng cao', color: 'red', default: 10 },
                  ].map(d => (
                    <div class="flex items-center gap-3">
                      <span class="text-xs font-medium text-gray-600 dark:text-gray-400 w-28 flex-shrink-0">{d.label}</span>
                      <input type="range" min="0" max="80" value={d.default} step="5"
                        class={`flex-1 accent-${d.color}-500`} data-difficulty={d.key} id={`diff-${d.key}`}/>
                      <span class="text-xs font-bold text-gray-700 dark:text-gray-300 w-8 text-right" id={`diff-${d.key}-val`}>{d.default}%</span>
                    </div>
                  ))}
                </div>
              </div>

              <div class="mt-5">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Hướng dẫn thêm (tùy chọn)</label>
                <textarea id="cfg-custom" rows="2" placeholder="VD: Tập trung vào Unit 1-3, grammar: present perfect..."
                  class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm focus:ring-2 focus:ring-purple-500 outline-none resize-none transition-all"></textarea>
              </div>
            </div>

            <!-- Ma trận config -->
            <div id="matrix-config" class="hidden bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm p-6">
              <h2 class="text-base font-bold text-gray-900 dark:text-gray-100 mb-4">📊 Ma trận đề thi</h2>
              <div class="overflow-x-auto">
                <table class="text-xs w-full border-collapse">
                  <thead>
                    <tr class="bg-gray-50 dark:bg-gray-700">
                      <th class="px-2 py-2 text-left border border-gray-200 dark:border-gray-600">Kỹ năng/Chủ đề</th>
                      <th class="px-2 py-2 border border-gray-200 dark:border-gray-600 text-green-600">NB</th>
                      <th class="px-2 py-2 border border-gray-200 dark:border-gray-600 text-blue-600">TH</th>
                      <th class="px-2 py-2 border border-gray-200 dark:border-gray-600 text-orange-600">VD</th>
                      <th class="px-2 py-2 border border-gray-200 dark:border-gray-600 text-red-600">VDC</th>
                    </tr>
                  </thead>
                  <tbody id="matrix-body">
                    {[
                      { topic: 'Từ vựng', nb: 4, th: 3, vd: 2, vdc: 1 },
                      { topic: 'Ngữ pháp', nb: 4, th: 5, vd: 3, vdc: 1 },
                      { topic: 'Đọc hiểu', nb: 2, th: 4, vd: 3, vdc: 1 },
                      { topic: 'Nghe hiểu', nb: 2, th: 2, vd: 2, vdc: 1 },
                    ].map((row, ri) => (
                      <tr>
                        <td class="px-2 py-1.5 border border-gray-200 dark:border-gray-600">
                          <input type="text" value={row.topic} class="w-full bg-transparent text-gray-700 dark:text-gray-300 outline-none" data-matrix="topic" data-row={ri}/>
                        </td>
                        {['nb','th','vd','vdc'].map(k => (
                          <td class="px-1 py-1.5 border border-gray-200 dark:border-gray-600 text-center">
                            <input type="number" min="0" max="20" value={(row as any)[k]}
                              class="w-12 text-center bg-transparent text-gray-700 dark:text-gray-300 outline-none"
                              data-matrix={k} data-row={ri}/>
                          </td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <button id="add-matrix-row" class="mt-2 text-xs text-purple-600 hover:text-purple-800 font-medium">+ Thêm hàng</button>
            </div>
          </div>
        </div>

        <!-- Generate button -->
        <div class="mt-8 flex justify-end">
          <button id="btn-generate" class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-purple-600 to-violet-600 hover:from-purple-700 hover:to-violet-700 text-white font-bold rounded-2xl shadow-xl shadow-purple-300 dark:shadow-purple-900 transition-all hover:scale-105 text-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Tạo đề với AI →
          </button>
        </div>
      </div>

      <!-- STEP 2: Generating -->
      <div id="step-2" class="step-panel hidden">
        <div class="text-center py-20">
          <div class="w-24 h-24 relative mx-auto mb-6">
            <div class="absolute inset-0 bg-purple-200 dark:bg-purple-900/40 rounded-full animate-ping"></div>
            <div class="relative w-24 h-24 bg-gradient-to-br from-purple-500 to-violet-600 rounded-full flex items-center justify-center text-4xl">🤖</div>
          </div>
          <h2 class="text-2xl font-black text-gray-900 dark:text-gray-100 mb-3">AI đang tạo đề thi...</h2>
          <p class="text-gray-500 dark:text-gray-400 mb-8" id="gen-status">Đang gọi Gemini AI, vui lòng chờ...</p>
          <div class="w-full max-w-sm mx-auto bg-gray-200 dark:bg-gray-700 rounded-full h-3">
            <div id="gen-progress" class="bg-gradient-to-r from-purple-500 to-violet-500 h-3 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
        </div>
      </div>

      <!-- STEP 3: Review & Edit -->
      <div id="step-3" class="step-panel hidden">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">📋 Xem & Chỉnh sửa câu hỏi</h2>
          <div class="flex gap-3">
            <button id="btn-regenerate" class="inline-flex items-center gap-2 px-4 py-2.5 border-2 border-purple-500 text-purple-600 dark:text-purple-400 font-semibold rounded-xl hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-all text-sm">
              🔄 Tạo lại
            </button>
            <button id="btn-to-step4" class="inline-flex items-center gap-2 px-5 py-2.5 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-xl transition-all text-sm">
              Tiếp theo →
            </button>
          </div>
        </div>
        <div id="questions-editor" class="space-y-4">
          <!-- Questions rendered here by JS -->
        </div>
        <div class="mt-6 flex justify-end gap-3">
          <button id="btn-add-question" class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition-all text-sm">
            + Thêm câu hỏi
          </button>
          <button id="btn-to-step4-2" class="inline-flex items-center gap-2 px-6 py-2.5 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-xl transition-all">
            Tiếp theo →
          </button>
        </div>
      </div>

      <!-- STEP 4: Save & Publish -->
      <div id="step-4" class="step-panel hidden max-w-2xl mx-auto">
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm p-8">
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-6">💾 Lưu & Xuất bản đề thi</h2>

          <div class="space-y-4">
            <div class="p-4 bg-purple-50 dark:bg-purple-900/20 rounded-xl border border-purple-100 dark:border-purple-800">
              <div class="text-sm font-medium text-purple-800 dark:text-purple-300 mb-1">Tên đề thi:</div>
              <div class="font-bold text-gray-900 dark:text-gray-100" id="review-title"></div>
            </div>

            <div class="grid grid-cols-3 gap-3 text-center">
              <div class="p-3 bg-gray-50 dark:bg-gray-700/50 rounded-xl">
                <div class="text-2xl font-black text-purple-600 dark:text-purple-400" id="review-count">0</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Câu hỏi</div>
              </div>
              <div class="p-3 bg-gray-50 dark:bg-gray-700/50 rounded-xl">
                <div class="text-2xl font-black text-purple-600 dark:text-purple-400" id="review-duration">0</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Phút</div>
              </div>
              <div class="p-3 bg-gray-50 dark:bg-gray-700/50 rounded-xl">
                <div class="text-2xl font-black text-purple-600 dark:text-purple-400" id="review-grade">-</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Lớp</div>
              </div>
            </div>

            <div class="flex items-center gap-3 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-xl">
              <input type="checkbox" id="cfg-publish" class="w-4 h-4 accent-purple-600" checked/>
              <label for="cfg-publish" class="text-sm font-medium text-gray-700 dark:text-gray-300 cursor-pointer">
                Xuất bản ngay (học sinh có thể thấy và làm bài)
              </label>
            </div>
          </div>

          <div class="flex gap-3 mt-6">
            <button id="btn-back-to-3" class="flex-1 py-3 border-2 border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-semibold rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition-all">
              ← Sửa lại
            </button>
            <button id="btn-save-exam" class="flex-1 py-3 bg-gradient-to-r from-purple-600 to-violet-600 hover:from-purple-700 hover:to-violet-700 text-white font-bold rounded-xl shadow-lg transition-all">
              💾 Lưu đề thi
            </button>
          </div>
        </div>
      </div>

      <!-- STEP 5: Success -->
      <div id="step-success" class="step-panel hidden text-center py-16">
        <div class="text-7xl mb-6">🎉</div>
        <h2 class="text-3xl font-black text-gray-900 dark:text-gray-100 mb-3">Đề thi đã được tạo!</h2>
        <p class="text-gray-500 dark:text-gray-400 mb-8">Học sinh có thể làm bài ngay bây giờ</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a id="link-view-exam" href="/de-thi" class="inline-flex items-center gap-2 px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-bold rounded-xl transition-all">
            👁 Xem đề thi
          </a>
          <a id="link-take-exam" href="/de-thi" class="inline-flex items-center gap-2 px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl transition-all">
            🎯 Thi ngay
          </a>
          <button id="btn-create-another" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-purple-500 text-purple-600 dark:text-purple-400 font-bold rounded-xl hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-all">
            + Tạo đề khác
          </button>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ geminiKey, supabaseUrl, supabaseKey, preType, allLessons: lessons.map(l => ({ id: l.id, name: l.name, grade: l.conf_grade })) }}>
    // ─── State ───────────────────────────────────────────────
    let currentStep = 1;
    let examType = preType || 'bai';
    let semester = null;
    let generatedQuestions = [];

    // ─── Auth check ──────────────────────────────────────────
    async function checkAuth() {
      try {
        const { createClient } = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm');
        const sb = createClient(supabaseUrl, supabaseKey);
        const { data: { session } } = await sb.auth.getSession();

        if (!session) {
          document.getElementById('auth-gate').classList.remove('hidden');
          return false;
        }

        // Check role
        const { data: profile } = await sb.from('profiles').select('role').eq('id', session.user.id).single();
        if (!profile || !['admin', 'teacher'].includes(profile.role)) {
          document.getElementById('auth-gate').classList.remove('hidden');
          document.querySelector('#auth-gate h2').textContent = 'Không có quyền tạo đề';
          document.querySelector('#auth-gate p').textContent = 'Chỉ Admin và Giáo viên mới có thể tạo đề thi.';
          return false;
        }

        document.getElementById('creator-ui').classList.remove('hidden');
        return { sb, user: session.user };
      } catch (e) {
        console.error('Auth check failed:', e);
        document.getElementById('creator-ui').classList.remove('hidden'); // fallback for dev
        return true;
      }
    }

    // ─── UI helpers ──────────────────────────────────────────
    function goToStep(n) {
      document.querySelectorAll('.step-panel').forEach(el => el.classList.add('hidden'));
      const panel = document.getElementById(`step-${n}`) || document.getElementById('step-success');
      if (panel) panel.classList.remove('hidden');
      currentStep = n;

      // Update step indicator dots
      document.querySelectorAll('.step-item').forEach(item => {
        const stepN = parseInt(item.dataset.step);
        const dot = item.querySelector('.step-dot');
        const label = item.querySelector('span:not(.step-dot)');
        if (stepN <= n && n <= 4) {
          dot.className = 'step-dot w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-purple-600 text-white';
          if (label) label.className = 'hidden sm:block text-sm font-medium text-purple-600 dark:text-purple-400';
        } else {
          dot.className = 'step-dot w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-gray-200 dark:bg-gray-700 text-gray-500 dark:text-gray-400';
          if (label) label.className = 'hidden sm:block text-sm font-medium text-gray-400';
        }
      });
    }

    // ─── Type selector ───────────────────────────────────────
    function setupTypeSelector() {
      const lessonGroup = document.getElementById('cfg-lesson-group');
      const semesterGroup = document.getElementById('cfg-semester-group');
      const matrixConfig = document.getElementById('matrix-config');

      document.querySelectorAll('.type-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          examType = btn.dataset.type;
          document.querySelectorAll('.type-btn').forEach(b => {
            b.classList.remove('border-purple-500', 'bg-purple-50', 'dark:bg-purple-900/20');
            b.classList.add('border-gray-200', 'dark:border-gray-600');
          });
          btn.classList.add('border-purple-500', 'bg-purple-50', 'dark:bg-purple-900/20');
          btn.classList.remove('border-gray-200', 'dark:border-gray-600');

          lessonGroup.classList.toggle('hidden', examType !== 'bai');
          semesterGroup.classList.toggle('hidden', examType !== 'hoc-ky');
          matrixConfig.classList.toggle('hidden', examType !== 'ma-tran');
        });
      });

      // Pre-select if type in URL
      if (preType) {
        document.querySelector(`[data-type="${preType}"]`)?.click();
      }
    }

    // ─── Difficulty sliders ──────────────────────────────────
    function setupSliders() {
      document.getElementById('cfg-num-questions').addEventListener('input', e => {
        document.getElementById('num-q-display').textContent = e.target.value;
      });
      ['nhan_biet', 'thong_hieu', 'van_dung', 'van_dung_cao'].forEach(key => {
        const input = document.getElementById(`diff-${key}`);
        const display = document.getElementById(`diff-${key}-val`);
        input?.addEventListener('input', e => { display.textContent = e.target.value + '%'; });
      });
    }

    // ─── Semester buttons ────────────────────────────────────
    function setupSemesterBtns() {
      document.querySelectorAll('.semester-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          semester = parseInt(btn.dataset.sem);
          document.querySelectorAll('.semester-btn').forEach(b => {
            b.classList.remove('border-purple-500', 'bg-purple-50');
          });
          btn.classList.add('border-purple-500', 'bg-purple-50');
        });
      });
    }

    // ─── Generate questions ──────────────────────────────────
    async function generateQuestions() {
      const title = document.getElementById('cfg-title').value.trim();
      if (!title) { alert('Vui lòng nhập tên đề thi!'); return; }
      if (!examType) { alert('Vui lòng chọn loại đề!'); return; }

      const grade = document.getElementById('cfg-grade').value;
      const numQ = parseInt(document.getElementById('cfg-num-questions').value);
      const custom = document.getElementById('cfg-custom').value;

      const difficulty_mix = {
        nhan_biet: parseInt(document.getElementById('diff-nhan_biet').value),
        thong_hieu: parseInt(document.getElementById('diff-thong_hieu').value),
        van_dung: parseInt(document.getElementById('diff-van_dung').value),
        van_dung_cao: parseInt(document.getElementById('diff-van_dung_cao').value),
      };

      goToStep(2);
      updateProgress('Đang kết nối Gemini AI...', 10);

      try {
        if (!geminiKey) throw new Error('Chưa cấu hình Gemini API Key. Thêm PUBLIC_GEMINI_API_KEY vào .env');

        const GEMINI_URL = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${geminiKey}`;

        let prompt = '';

        if (examType === 'thpt') {
          updateProgress('Đang tạo đề THPT 2026 (100 câu)...', 20);
          prompt = buildThptPrompt(grade);
        } else if (examType === 'ma-tran') {
          updateProgress('Đang đọc ma trận...', 20);
          const matrix = readMatrix();
          prompt = buildMatrixPrompt(matrix, grade, numQ);
        } else {
          let lessonName = '';
          if (examType === 'bai') {
            const lessonId = document.getElementById('cfg-lesson').value;
            const lesson = allLessons.find(l => l.id === lessonId);
            lessonName = lesson?.name || '';
          }
          prompt = buildGeneralPrompt({ grade, numQ, examType, difficulty_mix, custom, lessonName, title, semester });
        }

        updateProgress('AI đang sinh câu hỏi...', 40);

        const res = await fetch(GEMINI_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: prompt }] }],
            generationConfig: { temperature: 0.4, maxOutputTokens: 8192 }
          })
        });

        if (!res.ok) {
          if (res.status === 429) {
            throw new Error('Hệ thống AI đang quá tải hoặc bạn đã hết lượt tạo câu hỏi miễn phí (Lỗi 429). Vui lòng thử lại sau vài phút hoặc giảm số lượng câu hỏi.');
          }
          const err = await res.json();
          throw new Error(err?.error?.message || `Gemini API lỗi: ${res.status}`);
        }

        updateProgress('Đang xử lý kết quả...', 70);
        const data = await res.json();
        const text = data?.candidates?.[0]?.content?.parts?.[0]?.text || '';

        const questions = parseGeminiResponse(text);
        if (!questions || questions.length === 0) throw new Error('AI không trả về câu hỏi. Thử lại!');

        generatedQuestions = questions.map((q, i) => ({ ...q, id: `q${i+1}` }));

        updateProgress('Hoàn tất!', 100);
        await new Promise(r => setTimeout(r, 600));

        renderQuestionsEditor();
        goToStep(3);
      } catch (err) {
        alert(`❌ Lỗi tạo đề: ${err.message}`);
        goToStep(1);
      }
    }

    function updateProgress(msg, pct) {
      document.getElementById('gen-status').textContent = msg;
      document.getElementById('gen-progress').style.width = pct + '%';
    }

    // ─── Prompt builders ─────────────────────────────────────
    function buildGeneralPrompt({ grade, numQ, examType, difficulty_mix, custom, lessonName, title, semester }) {
      const diffStr = Object.entries(difficulty_mix)
        .map(([k,v]) => `${k.replace(/_/g,' ')}: ${v}%`).join(', ');
      const context = lessonName
        ? `Bài học: ${lessonName}`
        : `Tiếng Anh lớp ${grade} Global Success${semester ? ` - Học kỳ ${semester}` : ''}`;

      return `Bạn là giáo viên Tiếng Anh THPT Việt Nam giỏi. Tạo ${numQ} câu hỏi trắc nghiệm (MCQ) cho đề: "${title}"
Context: ${context}
Mức độ: ${diffStr}
${custom ? `Yêu cầu thêm: ${custom}` : ''}

Quy tắc:
- Câu hỏi bằng Tiếng Anh
- 4 đáp án A/B/C/D (dạng text, không có "A. " prefix)
- correct: index 0-3 (0=A)
- Giải thích có thể bằng tiếng Việt
- difficulty: "nhan-biet" | "thong-hieu" | "van-dung" | "van-dung-cao"
- Bám sát SGK Global Success

CHỈ trả về JSON array:
[{"id":"q1","type":"mcq","question":"...","options":["option A","option B","option C","option D"],"correct":0,"explanation":"...","difficulty":"thong-hieu","skill":"grammar"}]`;
    }

    function buildThptPrompt(grade) {
      return `Tạo bộ đề thi TN THPT 2026 Tiếng Anh chuẩn, gồm 40 câu MCQ (rút gọn từ 100 câu để demo):
- 15 câu Language Focus (từ vựng + ngữ pháp)
- 15 câu Reading (2 đoạn đọc, mỗi đoạn 7-8 câu)
- 10 câu Listening (dạng text, có transcript)

Phù hợp trình độ lớp 12, chuẩn THPT 2026.

CHỈ trả về JSON array giống format sau:
[
  {"id":"q1","type":"mcq","question":"...","options":["A","B","C","D"],"correct":0,"explanation":"...","skill":"vocabulary"},
  {"id":"q5","type":"reading","passage":"đoạn văn...","questions":[{"question":"...","options":["A","B","C","D"],"correct":1,"explanation":"..."}]},
  {"id":"q15","type":"listening","transcript":"script...","audio_url":null,"questions":[{"question":"...","options":["A","B","C","D"],"correct":2,"explanation":"..."}]}
]`;
    }

    function buildMatrixPrompt(matrix, grade, numQ) {
      const rows = matrix.map(r =>
        `${r.topic}: NB=${r.nb}, TH=${r.th}, VD=${r.vd}, VDC=${r.vdc}`
      ).join('\n');
      return `Tạo đề Tiếng Anh lớp ${grade} theo ma trận:
${rows}
Tổng: ${numQ} câu MCQ

CHỈ JSON array:
[{"id":"q1","type":"mcq","question":"...","options":["A","B","C","D"],"correct":0,"explanation":"...","difficulty":"nhan-biet","skill":"vocabulary"}]`;
    }

    function readMatrix() {
      const rows = [];
      document.querySelectorAll('#matrix-body tr').forEach(tr => {
        rows.push({
          topic: tr.querySelector('[data-matrix="topic"]')?.value || '',
          nb: parseInt(tr.querySelector('[data-matrix="nb"]')?.value) || 0,
          th: parseInt(tr.querySelector('[data-matrix="th"]')?.value) || 0,
          vd: parseInt(tr.querySelector('[data-matrix="vd"]')?.value) || 0,
          vdc: parseInt(tr.querySelector('[data-matrix="vdc"]')?.value) || 0,
        });
      });
      return rows;
    }

    function parseGeminiResponse(text) {
      const jsonMatch = text.match(/```(?:json)?\s*([\s\S]*?)```/);
      const jsonStr = (jsonMatch ? jsonMatch[1] : text).trim();
      try {
        const parsed = JSON.parse(jsonStr);
        return Array.isArray(parsed) ? parsed : parsed.questions || parsed.sections?.flatMap(s => s.questions) || [];
      } catch {
        const arrMatch = jsonStr.match(/(\[[\s\S]*\])/);
        if (arrMatch) return JSON.parse(arrMatch[1]);
        return [];
      }
    }

    // ─── Questions editor ────────────────────────────────────
    function renderQuestionsEditor() {
      const container = document.getElementById('questions-editor');
      container.innerHTML = '';

      generatedQuestions.forEach((q, i) => {
        const div = document.createElement('div');
        div.className = 'bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4';

        const typeLabel = {
          mcq: '☑️ MCQ', reading: '📖 Đọc hiểu', listening: '🎧 Nghe hiểu',
          sa: '✏️ Điền', essay: '✍️ Tự luận', msq: '⚖️ Đúng/Sai'
        }[q.type] || '❓';

        const labels = ['A','B','C','D','E','F'];

        if (q.type === 'reading' || q.type === 'listening') {
          div.innerHTML = `
            <div class="flex items-center gap-2 mb-3">
              <span class="w-7 h-7 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400 rounded-lg flex items-center justify-center text-xs font-bold">${i+1}</span>
              <span class="text-xs font-semibold text-indigo-600 dark:text-indigo-400">${typeLabel}</span>
              <span class="text-xs text-gray-500 dark:text-gray-400 ml-auto">${(q.questions||[]).length} câu hỏi phụ</span>
            </div>
            <textarea class="w-full text-sm text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 border border-gray-200 dark:border-gray-600 resize-none" rows="4" data-q="${i}" data-field="${q.type==='reading'?'passage':'transcript'}">${q.passage||q.transcript||''}</textarea>
            <div class="text-xs text-gray-400 mt-1">Chỉnh sửa ${q.type==='reading'?'đoạn văn':'transcript'}. Câu hỏi phụ không thể sửa trong giao diện này.</div>
          `;
        } else {
          div.innerHTML = `
            <div class="flex items-center gap-2 mb-3">
              <span class="w-7 h-7 bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400 rounded-lg flex items-center justify-center text-xs font-bold">${i+1}</span>
              <span class="text-xs font-semibold text-purple-600 dark:text-purple-400">${typeLabel}</span>
              <button class="ml-auto text-red-400 hover:text-red-600 text-xs" onclick="removeQuestion(${i})">🗑 Xóa</button>
            </div>
            <textarea class="w-full text-sm font-medium text-gray-800 dark:text-gray-200 bg-transparent border-none outline-none resize-none mb-2 focus:bg-gray-50 dark:focus:bg-gray-700/50 rounded-lg px-2 py-1" rows="2" data-q="${i}" data-field="question">${q.question||q.question_text||''}</textarea>
            ${q.options ? `<div class="grid grid-cols-2 gap-2 mt-1">
              ${q.options.map((opt, oi) => `
                <div class="flex items-center gap-1.5">
                  <span class="text-xs font-bold ${oi === (q.correct||0) ? 'text-green-600' : 'text-gray-400'}">${labels[oi]}.</span>
                  <input type="text" value="${opt.replace(/^[ABCD]\.\s*/,'')}" class="flex-1 text-xs text-gray-700 dark:text-gray-300 bg-transparent outline-none border-b border-transparent focus:border-purple-400 py-0.5 ${oi === (q.correct||0) ? 'font-semibold text-green-700 dark:text-green-400' : ''}" data-q="${i}" data-opt="${oi}"/>
                </div>`).join('')}
            </div>` : ''}
          `;
        }

        container.appendChild(div);
      });

      // Sync edits back to generatedQuestions
      container.querySelectorAll('[data-field="question"]').forEach(el => {
        el.addEventListener('input', () => {
          const qi = parseInt(el.dataset.q);
          generatedQuestions[qi].question = el.value;
        });
      });
      ['passage','transcript'].forEach(field => {
        container.querySelectorAll(`[data-field="${field}"]`).forEach(el => {
          el.addEventListener('input', () => {
            const qi = parseInt(el.dataset.q);
            generatedQuestions[qi][field] = el.value;
          });
        });
      });
      container.querySelectorAll('[data-opt]').forEach(el => {
        el.addEventListener('input', () => {
          const qi = parseInt(el.dataset.q);
          const oi = parseInt(el.dataset.opt);
          if (generatedQuestions[qi].options) generatedQuestions[qi].options[oi] = el.value;
        });
      });
    }

    window.removeQuestion = function(i) {
      generatedQuestions.splice(i, 1);
      renderQuestionsEditor();
    };

    // ─── Save exam ───────────────────────────────────────────
    async function saveExam() {
      const title = document.getElementById('cfg-title').value.trim();
      const grade = document.getElementById('cfg-grade').value;
      const duration = parseInt(document.getElementById('cfg-duration').value);
      const isPublished = document.getElementById('cfg-publish').checked;

      const slug = generateSlug(title);

      try {
        const { createClient } = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm');
        const sb = createClient(supabaseUrl, supabaseKey);
        const { data: { session } } = await sb.auth.getSession();

        const examData = {
          title, slug, grade, duration_minutes: duration,
          exam_type: examType, subject: 'tieng-anh',
          semester: semester || null,
          questions: generatedQuestions,
          is_published: isPublished,
          created_by: session?.user?.id || null,
        };

        const { data, error } = await sb.from('exam_papers').insert(examData).select().single();
        if (error) throw error;

        document.getElementById('link-view-exam').href = `/de-thi/${slug}`;
        document.getElementById('link-take-exam').href = `/de-thi/lam-bai/${slug}`;
        goToStep('success');
      } catch (err) {
        alert(`❌ Lỗi lưu đề: ${err.message}`);
      }
    }

    function generateSlug(title) {
      const ts = Date.now().toString(36);
      const slug = title.toLowerCase()
        .replace(/[àáạảãâầấậẩẫăằắặẳẵ]/g,'a')
        .replace(/[èéẹẻẽêềếệểễ]/g,'e')
        .replace(/[ìíịỉĩ]/g,'i')
        .replace(/[òóọỏõôồốộổỗơờớợởỡ]/g,'o')
        .replace(/[ùúụủũưừứựửữ]/g,'u')
        .replace(/[ỳýỵỷỹ]/g,'y')
        .replace(/đ/g,'d')
        .replace(/[^a-z0-9\s-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').slice(0,50);
      return `${slug}-${ts}`;
    }

    // ─── Init ─────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', async () => {
      const authResult = await checkAuth();
      if (!authResult) return;

      setupTypeSelector();
      setupSliders();
      setupSemesterBtns();

      document.getElementById('btn-generate')?.addEventListener('click', generateQuestions);
      document.getElementById('btn-regenerate')?.addEventListener('click', generateQuestions);
      document.getElementById('btn-to-step4')?.addEventListener('click', () => {
        document.getElementById('review-title').textContent = document.getElementById('cfg-title').value;
        document.getElementById('review-count').textContent = generatedQuestions.length;
        document.getElementById('review-duration').textContent = document.getElementById('cfg-duration').value;
        document.getElementById('review-grade').textContent = document.getElementById('cfg-grade').value;
        goToStep(4);
      });
      document.getElementById('btn-to-step4-2')?.addEventListener('click', () => document.getElementById('btn-to-step4')?.click());
      document.getElementById('btn-back-to-3')?.addEventListener('click', () => goToStep(3));
      document.getElementById('btn-save-exam')?.addEventListener('click', saveExam);
      document.getElementById('btn-create-another')?.addEventListener('click', () => {
        generatedQuestions = [];
        document.getElementById('cfg-title').value = '';
        goToStep(1);
      });
    });
  </script>
</Layout>
