---
interface Props {
  items: {
    label: string;
    href?: string;
  }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="flex items-center space-x-2 text-sm">
  {items.map((item, index) => (
    <div class="flex items-center">
      {index > 0 && (
        <svg
          class="w-4 h-4 mx-2 text-gray-400"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      )}
      {item.href ? (
        <a
          href={item.href}
          class="text-gray-600 hover:text-primary-600 transition-colors font-medium hover:underline"
        >
          {item.label}
        </a>
      ) : (
        <span class="text-gray-900 font-semibold">{item.label}</span>
      )}
    </div>
  ))}
</nav>

<style>
  @reference "tailwindcss";
  nav {
    @apply overflow-x-auto;
  }
</style>
